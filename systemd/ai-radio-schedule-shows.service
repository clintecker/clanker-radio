[Unit]
Description=AI Radio Schedule Shows Polling
Documentation=https://github.com/clintecker/clanker-radio
Wants=ai-radio-liquidsoap.service

[Service]
Type=oneshot
User=ai-radio
Group=ai-radio
WorkingDirectory=/srv/ai_radio
ExecStart=/srv/ai_radio/.venv/bin/python /srv/ai_radio/scripts/schedule_shows.py

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=schedule-shows

[Install]
WantedBy=multi-user.target
